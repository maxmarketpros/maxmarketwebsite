# Google PageSpeed Insights API key — exposed to the browser at build time.
# The audit tool calls Google PSI directly from the browser to avoid Netlify
# function timeouts on slow sites.
#
# IMPORTANT: lock this key down in Google Cloud Console before deploying:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Open the key, set Application restrictions → HTTP referrers
#   3. Add your domains (e.g. https://maxmarketpros.com/*, http://localhost:3000/*)
#   4. Set API restrictions → Restrict key → PageSpeed Insights API only
NEXT_PUBLIC_PAGESPEED_API_KEY=

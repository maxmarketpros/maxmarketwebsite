# SEO Auditor tool currently runs all checks server-side from the page HTML
# and response headers. No external API keys required.

# Set to "true" when launching to allow search engines to index the site.
# Any other value (or unset) keeps the entire site noindex/nofollow and
# returns an empty sitemap + full disallow robots.txt.
NEXT_PUBLIC_SEO_INDEXABLE=false
